---
---
digraph flowchart {
  graph [layout = dot, rankdir = TB, splines = ortho, fontname = "Helvetica"];

  node [shape = box, style = filled, color = "#D2E3F3", fontcolor = black, fontname = "Helvetica"];

  A [label = "CNS Cell"];
  B [label = "Neuron"];
  C [label = "Glia"];
  D [label = "Pyramidal neuron"];
  E [label = "Bipolar neuron"];
  F [label = "Purkinje cell"]
  G [label = "Astrocyte"];
  H [label = "Microglia"];
  I [label = "Oligodendrocyte"];

  A -> B;
  A -> C;
  B -> D;
  B -> E;
  B -> F;
  C -> G;
  C -> H;
  C -> I;

  { rank = same; D; F }
  { rank = same; H; I }
  { rank = min; E }
  { rank = min; G }
}