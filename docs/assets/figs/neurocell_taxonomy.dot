digraph flowchart {
  graph [layout = dot, rankdir = TB, splines = ortho, fontname = "Helvetica"];

  node [shape = box, style = filled, color = "#D2E3F3", fontcolor = black, fontname = "Helvetica"];

  A [label = "CNS Cell"];
  B [label = "Glia"];
  C [label = "Neuron"];
  D [label = "Astrocyte"];
  E [label = "Microglia"];
  F [label = "Oligodendrocyte"];
  G [label = "Bipolar neuron"];
  H [label = "Purkinje cell"];
  I [label = "Pyramidal neuron"];


  A -> B;
  A -> C;
  B -> D;
  B -> E;
  B -> F;
  C -> G;
  C -> H;
  C -> I;
}